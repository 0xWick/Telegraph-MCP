# Telegraph MCP Server Configuration
# Drop your private key here and run: npm start

# ── Telegraph Node URLs ──────────────────────────────────────────────
# Required: The endpoints where your Telegraph services are running
TELEGRAPH_NODE_URL=http://13.237.89.59:7044
TELEGRAPH_ENGINE_URL=http://13.237.89.59:8080
TELEGRAPH_DAEMON_URL=http://13.237.89.59:8081

# ── Payment Key (Required) ──────────────────────────────────────────
# EVM private key (0x-prefixed hex, 32 bytes)
# Must have USDC on the configured network for x402 payments
TELEGRAPH_EVM_PRIVATE_KEY=0x_your_evm_private_key_here

# Optional: Solana private key for SVM payments
# TELEGRAPH_SOLANA_PRIVATE_KEY=your_base58_solana_key

# ── Payment Network (Optional) ──────────────────────────────────────
# EVM_NETWORK=eip155:*
# SVM_NETWORK=solana:*

# ── Refresh (Optional) ──────────────────────────────────────────────
# REFRESH_INTERVAL_MS=300000
